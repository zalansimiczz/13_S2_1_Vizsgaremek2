{
  "info": {
    "name": "Toll API AMMPS Tests",
    "_postman_id": "f1a2b3c4-5678-4abc-9def-111122223333",
    "description": "AMMPS környezethez - login + role check teszt",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login - placeholder demo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"placeholder@demo.hu\",\n  \"password\": \"demo_hash\"\n}"
        },
        "url": {
          "raw": "http://localhost/tollapi/login.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["tollapi", "login.php"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "",
              "pm.test('Login success true', function () {",
              "    pm.expect(json.success).to.eql(true);",
              "});",
              "",
              "pm.environment.set('token', json.token);",
              "pm.environment.set('role', json.user.role);"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin endpoint with token",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost/tollapi/admin_lista.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["tollapi", "admin_lista.php"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Not 401', function () {",
              "    pm.expect(pm.response.code).to.not.eql(401);",
              "});",
              "",
              "pm.test('Not 403', function () {",
              "    pm.expect(pm.response.code).to.not.eql(403);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin endpoint without token",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost/tollapi/admin_lista.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["tollapi", "admin_lista.php"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Expected 401', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
